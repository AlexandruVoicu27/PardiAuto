<Page x:Class="AutoPartsShop.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="760" d:DesignWidth="1200"
      Title="Login" Background="#1A202C" FontFamily="Segoe UI">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1A202C" Offset="0"/>
                <GradientStop Color="#2D3748" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border Width="400" Height="500" Background="White" CornerRadius="16" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="5" Opacity="0.3"/>
            </Border.Effect>

            <StackPanel Margin="40">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,10">
                    <TextBlock Text="Pardi" Foreground="#1A202C" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="Auto" Foreground="#3182CE" FontSize="28" FontWeight="Bold" Margin="5,0,0,0"/>
                </StackPanel>

                <TextBlock Text="Autentificare în sistem" Foreground="#718096" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <TextBlock Text="Utilizator / Email" Foreground="#4A5568" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                <Border Background="#F7FAFC" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Padding="10,8" Margin="0,0,0,20">
                    <TextBox BorderThickness="0" Background="Transparent" FontSize="15" Foreground="#2D3748" Text="admin@autoparts.ro"/>
                </Border>

                <TextBlock Text="Parolă" Foreground="#4A5568" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                <Border Background="#F7FAFC" CornerRadius="8" BorderThickness="1" BorderBrush="#E2E8F0" Padding="10,8" Margin="0,0,0,30">
                    <PasswordBox BorderThickness="0" Background="Transparent" FontSize="15"/>
                </Border>

                <Button Content="Conectare" Background="#3182CE" Foreground="White" FontSize="16" FontWeight="Bold" Height="45" Cursor="Hand" Margin="0,10,0,0">
                    <Button.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                                    </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2B6CB0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock HorizontalAlignment="Center" Margin="0,30,0,0" FontSize="12">
    <Hyperlink Click="Hyperlink_Click" Foreground="#718096" TextDecorations="None">
        <Hyperlink.Style>
            <Style TargetType="Hyperlink">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="#3182CE"/>
                        <Setter Property="TextDecorations" Value="Underline"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Hyperlink.Style>
        Nu ai cont? Creează un cont nou.
    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>