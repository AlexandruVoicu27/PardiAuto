<Window x:Class="AutoPartsShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pardi Auto - Dashboard" Height="760" Width="1200"
        WindowStartupLocation="CenterScreen" Background="#F7FAFC">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1A202C">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock FontSize="32" FontWeight="ExtraBold" HorizontalAlignment="Center">
                <Run Text="Pardi" Foreground="White"/>
                <Run Text="Auto" Foreground="#3182CE"/>
                    </TextBlock>
                    <TextBlock Text="Piese și Accesorii" Foreground="#A0AEC0" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Margin="10,20,10,0">
                    <Button x:Name="BtnAcasa" Click="BtnAcasa_Click" Content="🏠 Acasă" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Height="45" HorizontalContentAlignment="Left" Padding="20,0,0,0" Cursor="Hand"/>
                    <Button x:Name="BtnDashboardAdmin" Click="BtnDashboardAdmin_Click" Content="📊 Dashboard admin" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Height="45" HorizontalContentAlignment="Left" Padding="20,0,0,0" Cursor="Hand" Margin="0,5,0,0"/>
                    <Button x:Name="BtnAdminComenzi" Click="BtnAdminComenzi_Click" Content="📦 Comenzi" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Height="45" HorizontalContentAlignment="Left" Padding="20,0,0,0" Cursor="Hand" Margin="0,5,0,0"/>
                    <Button x:Name="BtnPlatiFacturi" Click="BtnPlatiFacturi_Click" Content="💳 Plăți / Facturi" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Height="45" HorizontalContentAlignment="Left" Padding="20,0,0,0" Cursor="Hand" Margin="0,5,0,0"/>
                    <Button x:Name="BtnPieseAuto" Click="BtnPieseAuto_Click" Content="⚙️ Piese Auto"  Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Height="45" HorizontalContentAlignment="Left" Padding="20,0,0,0" Cursor="Hand" Margin="0,5,0,0"/>
                    <Button x:Name="BtnComandaMea" Click="BtnComandaMea_Click" Content="🛒 Comanda mea"  Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Height="45" HorizontalContentAlignment="Left" Padding="20,0,0,0" Cursor="Hand" Margin="0,5,0,0"/>
                </StackPanel>

                <Button Click="BtnDeconectare_Click" x:Name="BtnDeconectare" Grid.Row="2" Content="🚪 Schimbă Contu" Background="#E53E3E" Foreground="White" BorderThickness="0" FontSize="15" FontWeight="SemiBold" Height="40" Margin="20" Cursor="Hand"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
                <Grid>
                    <TextBlock Text="Panou de Control" VerticalAlignment="Center" Margin="30,0,0,0" FontSize="20" FontWeight="SemiBold" Foreground="#2D3748"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,30,0">
                        <TextBlock x:Name="UserSalutText" Text="Salut" FontSize="16" FontWeight="Medium" Foreground="#4A5568" Margin="0,0,14,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ProfilUtilizator" VerticalAlignment="Center" FontSize="15">
                            <Hyperlink  Click="ProfilUtilizator_Click" Foreground="#3182CE" TextDecorations="None">
                                <Hyperlink.Style>
                                    <Style TargetType="Hyperlink">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="TextDecorations" Value="Underline"/>
                                                <Setter Property="Foreground" Value="#2B6CB0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Hyperlink.Style>
                                Profilul meu
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <Frame Grid.Row="1" Name="MainFrame" NavigationUIVisibility="Hidden" Background="#F7FAFC" Margin="10"/>
        </Grid>
    </Grid>
</Window>
