<Page x:Class="AutoPartsShop.ConfigurareAngajatiPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="ConfigurareAngajatiPage"
      Background="#F4F8FC">
    
    <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Configurare angajati"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#1F2D3D"
                       Margin="0,0,0,16"/>

            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#D9E2EC"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <DataGrid x:Name="UtilizatoriGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="80"/>
                        <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="2*"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                        <DataGridTextColumn Header="Rol" Binding="{Binding Rol}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#D9E2EC"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,16,0,0">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Promoveaza la angajat"
                            Background="#2F80ED"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Padding="16,8"
                            Margin="0,0,10,0"
                            Click="BtnPromoveazaAngajat_Click"/>

                    <Button x:Name="BtnPromoveazaAdministrator"
                            Content="Promoveaza la administrator"
                            Background="#2F80ED"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Padding="16,8"
                            Margin="0,0,10,0"
                            Click="BtnPromoveazaAdministrator_Click"/>

                    <Button Content="Transforma in client"
                             Background="#2F80ED"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Padding="16,8"
                            Margin="0,0,10,0"
                            Click="BtnTransformaClient_Click"/>

                    <Button Content="Reincarca"
                            Background="#6C7A89"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Padding="16,8"
                            Click="BtnReincarcaUtilizatori_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Page>
